  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "drizzle-kit": "^1.0.0-rc.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
