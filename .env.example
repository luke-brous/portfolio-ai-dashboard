# Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an Authorized redirect URI in Google Cloud Console.
# In Codespaces this will look like: https://<your-codespace-name>-3000.app.github.dev/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Free key from https://aistudio.google.com
GEMINI_API_KEY=

# Any random string, used to sign the session cookie
SESSION_SECRET=change-me
